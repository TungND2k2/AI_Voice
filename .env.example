# Copy file này thành .env và điền giá trị thực

# API key bảo vệ các endpoint public.
# Tạo bằng: openssl rand -hex 32
TTS_API_KEY=your-secret-api-key-here

# Cloudflare Tunnel token (dùng URL cố định, thay cho quick-tunnel).
# Hướng dẫn:
#   1. Đăng nhập Cloudflare Zero Trust dashboard
#   2. Networks > Tunnels > Create a tunnel
#   3. Đặt tên (vd: viet-tts), copy token
#   4. Trong docker-compose.yaml, bỏ comment Option A và comment Option B
CLOUDFLARE_TUNNEL_TOKEN=
